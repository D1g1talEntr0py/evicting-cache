{
  "name": "evicting-cache",
  "author": "D1g1talEntr0py",
  "version": "3.0.4",
  "license": "ISC",
  "description": "Cache implementation with an LRU evicting policy",
  "homepage": "https://github.com/D1g1talEntr0py/evicting-cache#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/D1g1talEntr0py/evicting-cache"
  },
  "bugs": {
    "url": "https://github.com/D1g1talEntr0py/evicting-cache/issues"
  },
  "maintainers": [
    {
      "name": "D1g1talEntr0py",
      "email": "jason.dimeo@gmail.com"
    }
  ],
  "engines": {
    "node": ">=20.16.0"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/evicting-cache.d.ts",
      "import": "./dist/evicting-cache.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsbuild",
    "build:watch": "tsbuild --watch",
    "type-check": "tsbuild --noEmit",
    "lint": "eslint ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@d1g1tal/tsbuild": "^1.6.0",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "browserslist": [
    "defaults",
    "not ios_saf < 15",
    "not op_mini all"
  ],
  "keywords": [
    "cache",
    "evicting-cache",
    "lru",
    "lru-cache",
    "evicting-lru-cache"
  ]
}
